<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottomNavigationView"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:background="@color/wemmie_card"
    android:gravity="center_vertical"
    android:elevation="8dp"
    android:weightSum="3">

    <!-- Spill Tab -->
    <LinearLayout
        android:id="@+id/navSpill"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/tvNavSpillIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tvNavSpillText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spill"
            android:textColor="@color/wemmie_text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Feed Tab -->
    <LinearLayout
        android:id="@+id/navFeed"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/tvNavFeedIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tvNavFeedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Feed"
            android:textColor="@color/wemmie_text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Profile Tab -->
    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/tvNavProfileIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tvNavProfileText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textColor="@color/wemmie_text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

</LinearLayout>
